{
  "extends": "@repo/tsconfig/tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "types": ["vite/client", "vite-plugin-monkey/client"],
    "skipLibCheck": true,
    "paths": {
      "@components/*": ["./src/components/*"],
      "@styles/*": ["./src/styles/*"]
    }
  },
  "include": ["src/**/*"]
}
