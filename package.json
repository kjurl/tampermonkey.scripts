{
  "name": "tampermonkey.scripts",
  "private": true,
  "type": "module",
  "scripts": {
    "build:all": "turbo run build && node ./scripts/aggregate-dist.js",
    "build:gemini": "turbo run build --filter=gemini-auto-temp",
    "build:pes": "turbo run build --filter=pes-files-fetch",
    "change": "changeset",
    "change:release": "turbo run build && changeset publish",
    "change:version": "changeset version",
    "commit": "cz",
    "dev": "turbo run dev",
    "dev:gemini": "turbo run dev --filter=gemini-auto-temp",
    "dev:pes": "turbo run dev --filter=pes-files-fetch",
    "menu": "./scripts/menu.sh"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "commitizen": "^4.3.2",
    "cz-customizable": "^7.5.4",
    "prettier": "^3.8.4",
    "prettier-plugin-sort-imports": "npm:@trivago/prettier-plugin-sort-imports@^6.0.2",
    "turbo": "^2.9.18"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [],
      "allowedVersions": {
        "vite-plugin-monkey>vite": "8"
      }
    }
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    },
    "cz-customizable": {
      "config": ".cz-config.cjs"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "scope-enum": [
        2,
        "always",
        [
          "repo",
          "shared",
          "pes-files-fetch",
          "gemini-auto-temp"
        ]
      ],
      "scope-empty": [
        2,
        "never"
      ]
    }
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": false,
    "quoteProps": "as-needed",
    "jsxSingleQuote": false,
    "trailingComma": "none",
    "bracketSpacing": true,
    "objectWrap": "collapse",
    "bracketSameLine": false,
    "arrowParens": "avoid",
    "proseWrap": "always",
    "singleAttributePerLine": false,
    "plugins": [
      "prettier-plugin-sort-imports"
    ],
    "importOrder": [
      "^[^{]*from",
      "^\\{.*from",
      "^(?!@components|@styles)@[a-zA-Z0-9_-]+/.*$",
      "^@(?:components|styles)/(.*)$",
      "^[./]"
    ],
    "importOrderSeparation": true,
    "importOrderSortSpecifiers": true
  }
}
